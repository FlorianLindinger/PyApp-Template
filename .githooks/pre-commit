#!/bin/sh
set -u

repo_root="$(git rev-parse --show-toplevel)" || exit 1
cd "$repo_root" || exit 1

checker="code/backend/DONT_CHANGE/scripts/git_hooks/pre_commit_backend_sync_policy.py"

if [ ! -f "$checker" ]; then
    echo "[pre-commit] Missing hook checker: $checker" >&2
    exit 1
fi

if [ -x "code/backend/DONT_CHANGE/backend_python/python.exe" ]; then
    "code/backend/DONT_CHANGE/backend_python/python.exe" "$checker"
elif command -v py >/dev/null 2>&1; then
    py -3 "$checker"
elif command -v python >/dev/null 2>&1; then
    python "$checker"
else
    echo "[pre-commit] Python is required to check backend sync policy." >&2
    echo "[pre-commit] Install Python or generate the backend runtime first." >&2
    exit 1
fi
