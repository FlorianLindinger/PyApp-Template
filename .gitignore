# Entries in this file will not be synchronized in git. 
# "!" before whitelists synchronization

# ============================
# ==== general gitignores ====
# ============================

# shortcuts in this folder:
/*.lnk
# whitelist shortcut to generate shortcuts in this folder:
!/▶*.lnk
# log files:
/logs/*
# crash log files:
/crash logs/*
# whitelist ".gitkeep" files to sync folders:
!.gitkeep

